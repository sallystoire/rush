# ── Serveur ──────────────────────────────────────────────────
NODE_ENV=production
PORT=8080                       # Railway l'injecte automatiquement

# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname   # Railway PostgreSQL plugin

# ── Frontend build (Vite) ─────────────────────────────────────
BASE_PATH=/                     # Toujours "/" sur Railway

# ── Discord Activity ──────────────────────────────────────────
DISCORD_CLIENT_ID=              # Application ID depuis discord.com/developers
DISCORD_CLIENT_SECRET=          # Client Secret depuis discord.com/developers
VITE_DISCORD_CLIENT_ID=         # Même valeur que DISCORD_CLIENT_ID (injecté à la compilation Vite)

# ── CORS (production) ─────────────────────────────────────────
APP_URL=https://your-app.up.railway.app   # URL publique du service Railway (optionnel, renforce le CORS)
